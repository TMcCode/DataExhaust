# Copy to secrets.toml for local Streamlit (`streamlit run ...`). Same TOML can be pasted in
# Streamlit Community Cloud → App → ⋮ Settings → Secrets.
#
# Keeping the SAME key in BOTH places locally is OK and common:
#   • Repo `.env` (see `.env.example`) — for `python load_mlp_master.py`, scripts, Jupyter
#   • This file as `secrets.toml` — mirrors cloud; macro_data reads it outside Streamlit too
#
# Replace placeholder values — do not commit real keys.

FRED_API_KEY = "your_fred_key_here"

# BLS Public Data API (optional — https://data.bls.gov/registrationEngine/)
# BLS_REGISTRATION_KEY = "your_bls_registration_key_here"

# Commodity columns in macro come from paste CSVs beside the scripts (no secret). See .env.example.
# USDA NASS API key (optional — only if you call usda_nass_data.py directly; macro uses CSVs by default)
# USDA_NASS_API_KEY = "your_usda_nass_key_here"

# Google Sheets (Streamlit Community Cloud): paste the full JSON as one string (or omit if you
# ship `data-exhaust-key.json` next to the repo for local only).
# Example (use your real JSON on one line or TOML triple-quoted block):
# GOOGLE_SERVICE_ACCOUNT_JSON = """{"type":"service_account","project_id":"..."}"""
#
# Optional: local path override (same as env) — not needed on Cloud if JSON secret is set above.
# GOOGLE_SHEETS_CREDENTIALS = "/absolute/path/to/key.json"
#
# Optional — fast Streamlit load from a pre-built gzip+pickle bundle (see load_mlp_master.py --gcs-snapshot-uri).
# Service account needs **Storage Object Viewer** on the object (and Writer to upload snapshots).
# MLP_GCS_SNAPSHOT_URI = "gs://data-exhaust_cloudbuild/source/mlp_dashboard_bundle.pkl.gz"
#
# Optional — absolute path to Google Trends monthly CSV (defaults to repo `gtrends_fast_casual_monthly.csv`).
# MLP_GTRENDS_CSV = "/absolute/path/to/gtrends_fast_casual_monthly.csv"
#
# Optional — older Trends CSV (path or gs://…) merged on `month` before the primary; dup months keep primary.
# MLP_GTRENDS_APPEND_CSV = "gs://your-bucket/gtrends_history.csv"
