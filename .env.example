# Copy to `.env` (gitignored). Or use only `.streamlit/secrets.toml` — macro_data reads both.
#
# Many people keep the SAME FRED_API_KEY in two local files on purpose:
#   • .env              → plain `python`, notebooks, tests (python-dotenv)
#   • .streamlit/secrets.toml → matches Streamlit Cloud TOML shape; `streamlit run` also uses it
#
# Order of precedence: shell env wins; then dotenv fills from .env if missing; then secrets.toml
# if still missing. Duplicate values are fine — you are not required to pick only one file.
#
FRED_API_KEY=paste_your_key_here

# Optional but recommended (higher limits): register at https://data.bls.gov/registrationEngine/
# BLS_REGISTRATION_KEY=paste_your_key_here

# Commodity benchmarks: macro merges broilers_turkeys_monthly_paste.csv + beef_cattle_prices_received_monthly_paste.csv
# (next to load_mlp_master.py). No key required. Use load_mlp_master.py --no-commodity-csvs to skip.
#
# USDA NASS Quick Stats API (optional — NOT used by macro by default; module usda_nass_data.py only): https://quickstats.nass.usda.gov/api
# USDA_NASS_API_KEY=paste_your_key_here
# USDA_NASS_CACHE_TTL_HOURS=72
# USDA_NASS_CACHE_REFRESH=1
# USDA_NASS_YEAR_CHUNK=6
# USDA_NASS_READ_TIMEOUT=120
#
# Optional — Streamlit loads this gzip+pickle bundle first (fast when hosted). Upload with:
#   python load_mlp_master.py --gcs-snapshot-uri gs://data-exhaust_cloudbuild/source/mlp_dashboard_bundle.pkl.gz
# Same service account JSON should include Storage read (often a broader key than Sheets-only).
# MLP_GCS_SNAPSHOT_URI=gs://data-exhaust_cloudbuild/source/mlp_dashboard_bundle.pkl.gz
#
# Google Trends CSV (optional path; default is repo `gtrends_fast_casual_monthly.csv`).
# MLP_GTRENDS_CSV=/absolute/path/to/gtrends_fast_casual_monthly.csv
#
# Older Trends CSV merged on `month` before primary (local or gs://); duplicate months keep primary.
# MLP_GTRENDS_APPEND_CSV=gs://your-bucket/gtrends_history.csv
